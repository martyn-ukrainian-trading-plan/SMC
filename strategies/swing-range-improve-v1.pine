//@version=6
indicator("Range STR v2.1", overlay=true, max_lines_count=500, max_boxes_count=500, max_labels_count=500)

// --- Inputs ---
gracePeriod = input.int(20, "Grace period (bars)", minval=5, maxval=200)
retracePct  = input.float(20.0, "Retracement %", minval=10, maxval=90, step=5) / 100.0
showRange   = input.bool(true, "Show range box")
showDebug   = input.bool(false, "Show labels")
useFractal  = input.bool(false, "Fractal filter", tooltip="Require swing point to be a fractal (N bars left/right with lower high or higher low)")
fractalBars = input.int(2, "Fractal bars (left/right)", minval=1, maxval=10)
rangeColor  = input.color(color.new(color.blue, 85), "Range color")
bullColor   = input.color(color.green, "Bull color")
bearColor   = input.color(color.red, "Bear color")

// --- Confirmed range ---
var float confHigh    = na
var int   confHighBar = na
var float confLow     = na
var int   confLowBar  = na

// --- Provisional swing points ---
var float swingHigh    = na
var int   swingHighBar = na
var float swingLow     = na
var int   swingLowBar  = na

// --- Active level lines (horizontal from swing point, extended until break) ---
var line activHighLine = na
var line activLowLine  = na

// --- State: 0=waiting, 1=hasBOS, 2=hasCallback, 3=hasCHoCH ---
var int state = 0
var int dir   = 0
var box rangeBox = na

// Helper: check fractal high — N bars left and right must have lower high
isFractalHigh(int barsAgo, int n) =>
    ok = true
    for i = 1 to n
        if high[barsAgo + i] >= high[barsAgo]
            ok := false
        if barsAgo - i >= 0 and high[barsAgo - i] >= high[barsAgo]
            ok := false
    ok

// Helper: check fractal low — N bars left and right must have higher low
isFractalLow(int barsAgo, int n) =>
    ok = true
    for i = 1 to n
        if low[barsAgo + i] <= low[barsAgo]
            ok := false
        if barsAgo - i >= 0 and low[barsAgo - i] <= low[barsAgo]
            ok := false
    ok

// Helper: fractal gate — pass if filter disabled or fractal confirmed
isValidSwingHigh(int swBar) =>
    not useFractal or isFractalHigh(bar_index - swBar, fractalBars)

isValidSwingLow(int swBar) =>
    not useFractal or isFractalLow(bar_index - swBar, fractalBars)

// Helper: draw dot at swing point
drawDot(int b, float price, bool isHigh, color c) =>
    label.new(b, price, "",
         style=label.style_circle,
         color=c, size=size.auto)

// Helper: draw horizontal level line from swing point to current bar
startLevel(int fromBar, float price, color c) =>
    line.new(fromBar, price, bar_index, price, color=c, width=1, style=line.style_dashed)

// ==========================================
// Phase 1: Grace period
// ==========================================
if bar_index <= gracePeriod
    if na(confHigh) or high > confHigh
        confHigh    := high
        confHighBar := bar_index
    if na(confLow) or low < confLow
        confLow     := low
        confLowBar  := bar_index
    if bar_index == gracePeriod
        swingHigh    := confHigh
        swingHighBar := confHighBar
        swingLow     := confLow
        swingLowBar  := confLowBar
        state := 2
        if confHighBar > confLowBar
            dir := 1
            drawDot(confLowBar, confLow, false, bullColor)
            drawDot(confHighBar, confHigh, true, bullColor)
            activHighLine := startLevel(confHighBar, confHigh, bearColor)
            activLowLine  := startLevel(confLowBar, confLow, bullColor)
        else
            dir := -1
            drawDot(confHighBar, confHigh, true, bearColor)
            drawDot(confLowBar, confLow, false, bearColor)
            activHighLine := startLevel(confHighBar, confHigh, bearColor)
            activLowLine  := startLevel(confLowBar, confLow, bullColor)

// ==========================================
// Extend active lines to current bar
// ==========================================
if not na(activHighLine)
    line.set_x2(activHighLine, bar_index)
if not na(activLowLine)
    line.set_x2(activLowLine, bar_index)

// ==========================================
// Phase 2: Main logic
// ==========================================
if bar_index > gracePeriod

    // =====================
    // State 0: waiting for first BOS
    // =====================
    if state == 0
        if dir == 1
            if low < swingLow
                swingLow    := low
                swingLowBar := bar_index
        if dir == -1
            if high > swingHigh
                swingHigh    := high
                swingHighBar := bar_index

        if high > confHigh
            // End high line at break bar
            if not na(activHighLine)
                line.set_x2(activHighLine, bar_index)
            drawDot(swingLowBar, swingLow, false, bullColor)
            activLowLine := startLevel(swingLowBar, swingLow, bullColor)
            dir          := 1
            state        := 1
            swingHigh    := high
            swingHighBar := bar_index
            if showDebug
                label.new(bar_index, high, "BOS↑", style=label.style_label_down, color=color.green, textcolor=color.white, size=size.small)
        else if low < confLow
            if not na(activLowLine)
                line.set_x2(activLowLine, bar_index)
            drawDot(swingHighBar, swingHigh, true, bearColor)
            activHighLine := startLevel(swingHighBar, swingHigh, bearColor)
            dir          := -1
            state        := 1
            swingLow     := low
            swingLowBar  := bar_index
            if showDebug
                label.new(bar_index, low, "BOS↓", style=label.style_label_up, color=color.red, textcolor=color.white, size=size.small)

    // =====================
    // State 1: hasBOS — track extreme, retrace → state 2
    // =====================
    else if state == 1
        if dir == 1
            if high > swingHigh
                swingHigh    := high
                swingHighBar := bar_index
            else
                moveSize = swingHigh - confLow
                if moveSize > 0
                    retraceLevel = swingHigh - moveSize * retracePct
                    if low < retraceLevel
                        // Retrace detected — always transition state
                        isFractal = isValidSwingHigh(swingHighBar)
                        if isFractal
                            drawDot(swingHighBar, swingHigh, true, bullColor)
                            activHighLine := startLevel(swingHighBar, swingHigh, bearColor)
                        confHigh     := swingHigh
                        confHighBar  := swingHighBar
                        confLow      := swingLow
                        confLowBar   := swingLowBar
                        swingLow     := low
                        swingLowBar  := bar_index
                        state        := 2
                        if showDebug
                            label.new(bar_index, low, isFractal ? "CB" : "CB~", style=label.style_label_up, color=color.blue, textcolor=color.white, size=size.small)

        if dir == -1
            if low < swingLow
                swingLow    := low
                swingLowBar := bar_index
            else
                moveSize = confHigh - swingLow
                if moveSize > 0
                    retraceLevel = swingLow + moveSize * retracePct
                    if high > retraceLevel
                        // Retrace detected — always transition state
                        isFractal = isValidSwingLow(swingLowBar)
                        if isFractal
                            drawDot(swingLowBar, swingLow, false, bearColor)
                            activLowLine := startLevel(swingLowBar, swingLow, bullColor)
                        confLow      := swingLow
                        confLowBar   := swingLowBar
                        confHigh     := swingHigh
                        confHighBar  := swingHighBar
                        swingHigh    := high
                        swingHighBar := bar_index
                        state        := 2
                        if showDebug
                            label.new(bar_index, high, isFractal ? "CB" : "CB~", style=label.style_label_down, color=color.orange, textcolor=color.white, size=size.small)

    // =====================
    // State 2: hasCallback — track HL/LH, BOS or CHoCH
    // =====================
    else if state == 2
        if dir == 1
            if low < swingLow
                swingLow    := low
                swingLowBar := bar_index

            if high > confHigh
                // BOS up
                if not na(activHighLine)
                    line.set_x2(activHighLine, bar_index)
                confLow      := swingLow
                confLowBar   := swingLowBar
                drawDot(swingLowBar, swingLow, false, bullColor)
                activLowLine := startLevel(swingLowBar, swingLow, bullColor)
                state        := 1
                swingHigh    := high
                swingHighBar := bar_index
                if showDebug
                    label.new(bar_index, high, "BOS↑", style=label.style_label_down, color=color.green, textcolor=color.white, size=size.small)

            else if low < confLow
                // CHoCH down
                if not na(activLowLine)
                    line.set_x2(activLowLine, bar_index)
                confHigh     := swingHigh
                confHighBar  := swingHighBar
                drawDot(swingHighBar, swingHigh, true, bearColor)
                activHighLine := startLevel(swingHighBar, swingHigh, bearColor)
                dir          := -1
                state        := 3
                swingLow     := low
                swingLowBar  := bar_index
                if showDebug
                    label.new(bar_index, low, "CHoCH↓", style=label.style_label_up, color=color.red, textcolor=color.white, size=size.small)

        if dir == -1
            if high > swingHigh
                swingHigh    := high
                swingHighBar := bar_index

            if low < confLow
                // BOS down
                if not na(activLowLine)
                    line.set_x2(activLowLine, bar_index)
                confHigh     := swingHigh
                confHighBar  := swingHighBar
                drawDot(swingHighBar, swingHigh, true, bearColor)
                activHighLine := startLevel(swingHighBar, swingHigh, bearColor)
                state        := 1
                swingLow     := low
                swingLowBar  := bar_index
                if showDebug
                    label.new(bar_index, low, "BOS↓", style=label.style_label_up, color=color.red, textcolor=color.white, size=size.small)

            else if high > confHigh
                // CHoCH up
                if not na(activHighLine)
                    line.set_x2(activHighLine, bar_index)
                confLow      := swingLow
                confLowBar   := swingLowBar
                drawDot(swingLowBar, swingLow, false, bullColor)
                activLowLine := startLevel(swingLowBar, swingLow, bullColor)
                dir          := 1
                state        := 3
                swingHigh    := high
                swingHighBar := bar_index
                if showDebug
                    label.new(bar_index, high, "CHoCH↑", style=label.style_label_down, color=color.green, textcolor=color.white, size=size.small)

    // =====================
    // State 3: hasCHoCH — same as hasBOS but trend flipped
    // =====================
    else if state == 3
        if dir == 1
            if high > swingHigh
                swingHigh    := high
                swingHighBar := bar_index
            else
                moveSize = swingHigh - confLow
                if moveSize > 0
                    retraceLevel = swingHigh - moveSize * retracePct
                    if low < retraceLevel
                        // Retrace detected — always transition state
                        isFractal = isValidSwingHigh(swingHighBar)
                        if isFractal
                            drawDot(swingHighBar, swingHigh, true, bullColor)
                            activHighLine := startLevel(swingHighBar, swingHigh, bearColor)
                        confHigh     := swingHigh
                        confHighBar  := swingHighBar
                        confLow      := swingLow
                        confLowBar   := swingLowBar
                        swingLow     := low
                        swingLowBar  := bar_index
                        state        := 2
                        if showDebug
                            label.new(bar_index, low, isFractal ? "CB" : "CB~", style=label.style_label_up, color=color.blue, textcolor=color.white, size=size.small)

        if dir == -1
            if low < swingLow
                swingLow    := low
                swingLowBar := bar_index
            else
                moveSize = confHigh - swingLow
                if moveSize > 0
                    retraceLevel = swingLow + moveSize * retracePct
                    if high > retraceLevel
                        // Retrace detected — always transition state
                        isFractal = isValidSwingLow(swingLowBar)
                        if isFractal
                            drawDot(swingLowBar, swingLow, false, bearColor)
                            activLowLine := startLevel(swingLowBar, swingLow, bullColor)
                        confLow      := swingLow
                        confLowBar   := swingLowBar
                        confHigh     := swingHigh
                        confHighBar  := swingHighBar
                        swingHigh    := high
                        swingHighBar := bar_index
                        state        := 2
                        if showDebug
                            label.new(bar_index, high, isFractal ? "CB" : "CB~", style=label.style_label_down, color=color.orange, textcolor=color.white, size=size.small)

// --- Range box ---
if showRange and not na(confHigh) and not na(confLow)
    if not na(rangeBox)
        box.delete(rangeBox)
    rangeBox := box.new(bar_index, confHigh, bar_index, confLow, border_color=color.new(rangeColor, 50), bgcolor=rangeColor)
